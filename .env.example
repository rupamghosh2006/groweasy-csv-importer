# This is a monorepo with frontend (Next.js) and server (Express).
# Copy the relevant .env.example in each subdirectory:
#
#   server/.env.example  →  server/.env   (for GEMINI_API_KEY)
#   frontend/.env.example → frontend/.env.local  (for NEXT_PUBLIC_API_URL)
#
# Do NOT commit .env or .env.local files.
